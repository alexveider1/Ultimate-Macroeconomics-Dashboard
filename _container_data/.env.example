POSTGRES_USERNAME=username
POSTGRES_PASSWORD=password

POSTGRES_LLM_USERNAME=llm_username
POSTGRES_LLM_PASSWORD=llm_password

QDRANT__SERVICE__API_KEY=some_api_key

# Hosting build only: this key is used by the agent service for the
# embedding model that powers semantic news search (RAG). It is NOT used
# for chat / agentic LLM calls — the chat-time API key is supplied by the
# end user via the in-browser credential form and forwarded to the agent
# as the X-LLM-API-Key request header. Never put your chat key here.
OPENAI_API_KEY=embedding_provider_api_key
